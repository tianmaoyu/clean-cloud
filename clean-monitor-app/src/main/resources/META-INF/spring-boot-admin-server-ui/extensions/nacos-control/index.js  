
import NacosControlView from './NacosControlView.vue';  // 如果使用 Vue 单文件组件

SBA.use({
  install({ viewRegistry, i18n }) {
    // 添加实例详情页的自定义视图
    viewRegistry.addView({
      name: "instances/nacos-control",   // 视图唯一标识
      parent: "instances",                // 父级为实例详情页
      path: "nacos-control",              // 路由路径
      component: NacosControlView,        // Vue 组件
      label: "Nacos 控制",                // 显示标签
      group: "operations",                // 分组（可选）
      order: 100,                         // 排序
      // 动态控制是否显示（例如检查实例是否支持某个端点）
      isEnabled: ({ instance }) => true   // 始终显示
    });

    // 可选：添加国际化翻译
    i18n.mergeLocaleMessage("zh", {
      "nacos-control": {
        label: "Nacos 控制"
      }
    });
  }
});